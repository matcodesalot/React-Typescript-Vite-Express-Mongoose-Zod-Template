{
  "name": "my-project",
  "private": true,
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=apps/server",
    "dev:client": "npm run dev --workspace=apps/client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:server": "npm run build --workspace=apps/server",
    "build:client": "npm run build --workspace=apps/client",
    "build": "npm run build:server && npm run build:client",
    "typecheck:server": "npm run typecheck --workspace=apps/server",
    "typecheck:client": "npm run typecheck --workspace=apps/client",
    "typecheck": "npm run typecheck:server && npm run typecheck:client"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
